<UserControl x:Class="ClientApp.Controls.PlayerUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Width="110">
            <TextBlock Height="15" Text="{Binding Username}" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
        </StackPanel>
    </Border>
</UserControl>
