<Window x:Class="ClientApp.IPInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter Server IP" Height="150" Width="300" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="10">
        <TextBlock Text="Enter the Server IP Address:" Margin="0,0,0,10"/>
        <TextBox x:Name="IpTextBox" Width="260" Height="30" Margin="0,0,0,10"/>
        <Button Content="OK" Width="75" HorizontalAlignment="Right" Click="OnOkClick"/>
    </StackPanel>
</Window>
