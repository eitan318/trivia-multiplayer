<Window x:Class="ClientApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClientApp.ViewModels"
        xmlns:local="clr-namespace:ClientApp"
        Title="MainWindow" Height="450" Width="800"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Template Selector -->
        <local:ViewModelToPageTemplateSelector x:Key="ViewModelToPageTemplateSelector" />
    </Window.Resources>

    <Grid>
        <!-- Frame for View Navigation -->
        <Frame Content="{Binding CurrentViewModel}"
               ContentTemplateSelector="{StaticResource ViewModelToPageTemplateSelector}" 
               NavigationUIVisibility="Hidden" />

        <!-- Back Button -->
        <Button Style="{StaticResource BackButtonStyle}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Command="{Binding BackCmd}"
                Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="1" />

        <!-- Error Message -->
        <TextBlock Text="{Binding ServerErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}" 
                   Visibility="{Binding ServerErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="10"
                   Panel.ZIndex="1" />
    </Grid>
</Window>
