<Window x:Class="ClientApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClientApp.ViewModels"
        xmlns:local="clr-namespace:ClientApp"
        Title="MainWindow" Height="450" Width="800"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        xmlns:controls="clr-namespace:ClientApp.Views.Controls"
        xmlns:converters="clr-namespace:ClientApp.Views.Converters"
        Style="{StaticResource MaterialDesignWindow}"
        Icon="/Assets/TriviaIcon3.ico"
        MinHeight="300" MinWidth="600">

    <DockPanel>
        <Grid DockPanel.Dock="Top"  Visibility="{Binding CurrentViewModel.HasNavBar, Converter={StaticResource BoolToVisibilityConverter}}">
           <!-- Top Bar -->
            <controls:TopBar  DataContext="{Binding CurrentViewModel.NavBarVM}"/> 
        </Grid>
        

        <!-- Main Content -->
        <Grid >

            <!-- Frame for View Navigation -->
            <Frame x:Name="MainContentFrame"
               NavigationUIVisibility="Hidden" />

            <!--Back Button-->
            <Button Style="{StaticResource BackButtonStyle}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="3"
                Command="{Binding BackCmd}"
                Visibility="{Binding WindowBackBtn, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="1" />

            <!-- Error Message -->
            <TextBlock Text="{Binding ServerErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}" 
                   Visibility="{Binding ServerErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="10"
                   Panel.ZIndex="1" />
        </Grid>
    </DockPanel>
</Window>
