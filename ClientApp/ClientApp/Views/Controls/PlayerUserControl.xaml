<UserControl x:Class="ClientApp.Views.Controls.PlayerUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ClientApp.Views.Converters"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
    <UserControl.Resources>
        <!-- Example: Create a converter to handle conditionally setting the border color -->
        <converters:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter"/>
    </UserControl.Resources>

    <Border BorderBrush="{Binding IsMe, Converter={StaticResource BoolToBorderBrushConverter}}"  
            BorderThickness="4" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center">

        <Border BorderBrush="Gray" BorderThickness="1" Padding="10" >
            <StackPanel Width="110">
                <TextBlock Height="15" Text="{Binding Username}" FontWeight="Bold" />
            </StackPanel>
        </Border>
    </Border>
</UserControl>

