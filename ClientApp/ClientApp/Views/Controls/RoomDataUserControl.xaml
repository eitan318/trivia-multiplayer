<UserControl x:Class="ClientApp.Views.Controls.RoomDataUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientApp.Views.Controls"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Orientation="Vertical">
        <TextBlock Text="{Binding RoomName, StringFormat='Room Name: {0}'}" FontWeight="Bold" FontSize="16" />
        <TextBlock Text="{Binding MaxPlayers, StringFormat='Max Players: {0}'}" />
        <TextBlock Text="{Binding NumOfQuestionsInGame, StringFormat='Questions: {0}'}" />
        <TextBlock Text="{Binding TimePerQuestion, StringFormat='Time per Question: {0} sec'}" />
    </StackPanel>
</UserControl>
