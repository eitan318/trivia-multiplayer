<UserControl x:Class="ClientApp.Views.Controls.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Height="37"
             Background="{DynamicResource MaterialDesignPaper}">


    <DockPanel Grid.Row="0" >
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,10,0">
            <Button Command="{Binding LogoutCmd}" Style="{StaticResource MaterialDesignIconButton}" Height="37" Margin="10,0,0,0">
                <materialDesign:PackIcon Kind="Logout" Width="30" Height="30"/>
            </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" HorizontalAlignment="Left" Margin="0,0,10,0">
            <!-- Back Button -->
            <Button Command="{Binding BackCmd}" 
                Visibility="{Binding ShowBackButton, Converter={StaticResource BoolToVisibilityConverter}}" 
                Style="{StaticResource MaterialDesignIconButton}" Height="37" Margin="10,0,0,0" DockPanel.Dock="Left">
                <materialDesign:PackIcon Kind="ArrowLeft" Width="30" Height="30"/>
            </Button>
            <materialDesign:PackIcon Kind="Account" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Width="30" Height="30" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TopBarUsername}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
        </StackPanel>
    </DockPanel>
</UserControl>
