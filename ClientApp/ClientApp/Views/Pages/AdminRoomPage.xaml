<Page x:Class="ClientApp.Views.Pages.AdminRoomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminRoomPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Admin Display -->
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock Text="Admin (You):" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"/>
            <controls:PlayerUserControl DataContext="{Binding Admin}"  Margin="0,0,100,0"/>
            <controls:RoomDataUserControl DataContext="{Binding RoomData}" />
        </StackPanel>

        <!-- List of players -->
        <GroupBox Header="Players" Grid.Row="1" Grid.Column="0" Margin="0,10,10,10">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Players}">
                    <!-- Define the layout for player items -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- Define the template for each player item -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:PlayerUserControl Margin="10"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,10,0,10" VerticalAlignment="Top">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,0,10"/>
            <Button Content="Start Game" Command="{Binding StartGameCommand}" Margin="0,0,0,10" />
            <Button Content="Close Room" Command="{Binding CloseRoomCommand}" />
        </StackPanel>
    </Grid>
</Page>
