<local:NavigablePage x:Class="ClientApp.Views.Pages.CreateRoomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CreateRoomPage">

    <Page.Resources>
        <!-- Converter to toggle visibility based on a boolean value -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <!-- Define rows for the layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <!-- Input fields section -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="0">
            <!-- TextBox for entering the room name -->
            <TextBox 
                materialDesign:HintAssist.Hint="Room name" 
                Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                Text="{Binding RoomName, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Width="80"
                Margin="0,0,10,0"/>

            <!-- NumericUpDown for specifying the number of players -->
            <materialDesign:NumericUpDown
                materialDesign:HintAssist.Hint="Players" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                Value="{Binding MaxPlayers, UpdateSourceTrigger=PropertyChanged}"
                Maximum="50"
                Minimum="1"
                Margin="0,0,10,0"/>

            <!-- NumericUpDown for specifying the question count -->
            <materialDesign:NumericUpDown
                materialDesign:HintAssist.Hint="Question count" 
                materialDesign:HintAssist.HelperText="{Binding QuestionCountError, Mode=TwoWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                Maximum="50"
                Minimum="1"
                Value="{Binding QuestionsCount, UpdateSourceTrigger=PropertyChanged}"
                Margin="0,0,10,0">
            </materialDesign:NumericUpDown>

            <!-- NumericUpDown for specifying the question timeout -->
            <materialDesign:NumericUpDown
                materialDesign:HintAssist.Hint="Question timeout" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                Value="{Binding QuestionTimeout, UpdateSourceTrigger=PropertyChanged}"
                Minimum="1"
                Margin="0,0,10,0"/>
        </StackPanel>

        <!-- Button for creating the room -->
        <Button Content="Create Room" 
                Command="{Binding CreateRoomCommand}" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Grid.Row="1" />

        <!-- List of players displayed in a grid -->
        <ItemsControl ItemsSource="{Binding Players}" Grid.Row="2"
                      Visibility="{Binding IsPlayerGridVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!-- Define the layout for player items -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="6" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- Define the template for each player item -->
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:PlayerUserControl />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</local:NavigablePage>
