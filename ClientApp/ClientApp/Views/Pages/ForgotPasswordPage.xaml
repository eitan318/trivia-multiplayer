<local:NavigablePage x:Class="ClientApp.Views.Pages.ForgotPasswordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      xmlns:fpvm="clr-namespace:ClientApp.ViewModels.ForgotPassword"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ForgotPasswordPage"
      Background="{DynamicResource MaterialDesignPaper}">

    <!-- Layout for the page -->
    <Grid>
        <!-- ContentControl dynamically loads the appropriate view based on the current step in the process -->
        <ContentControl Content="{Binding CurrentStep}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <ContentControl.Resources>

                <!-- Template for the "Email Step" -->
                <DataTemplate DataType="{x:Type fpvm:EmailStepViewModel}">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                        <Grid.RowDefinitions>
                            <!-- Define rows for header, description, input, button, and error message -->
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Page header -->
                        <TextBlock Grid.Row="0" 
                               Text="Forgot Password" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center" 
                               Margin="0,20,0,10"
                               Foreground="{DynamicResource MaterialDesignBody}"/>

                        <!-- Instruction for entering the email -->
                        <TextBlock Grid.Row="1" 
                               Text="Enter your email to receive a verification code:" 
                               FontSize="16" 
                               HorizontalAlignment="Center" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource MaterialDesignBody}"/>

                        <!-- TextBox for email input -->
                        <TextBox Grid.Row="2" 
                             FontSize="18" 
                             Width="300" 
                             HorizontalAlignment="Center" 
                             Margin="0,10,0,10"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Foreground="{DynamicResource MaterialDesignBody}"/>

                        <!-- Button to submit the email -->
                        <Button Grid.Row="3" 
                            Content="Submit" 
                            FontSize="16" 
                            Width="150" 
                            Height="40" 
                            HorizontalAlignment="Center"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding SubmitEmailCommand}" />

                        <!-- Error message display -->
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Grid.Row="4" Foreground="{StaticResource ErrorBrush}" 
                                   TextAlignment="Center" 
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>

                <!-- Template for the "Code Step" -->
                <DataTemplate DataType="{x:Type fpvm:CodeStepViewModel}">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                        <Grid.RowDefinitions>
                            <!-- Define rows for header, input fields, error message, and buttons -->
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header for code entry -->
                        <TextBlock Grid.Row="0" 
                   Text="Enter Verification Code" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,20,0,10"
                   Foreground="{DynamicResource MaterialDesignBody}"/>

                        <!-- Boxes for verification code input -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,30">
                            <ItemsControl ItemsSource="{Binding CodeBoxes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Width="50" 
                                                 Height="60" 
                                                 FontSize="30" 
                                                 Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                 HorizontalContentAlignment="Center" 
                                                 VerticalContentAlignment="Center"
                                                 MaxLength="1"
                                                 Margin="5"
                                                 Foreground="{DynamicResource MaterialDesignBody}"
                                                 PreviewTextInput="TextBox_PreviewTextInput"
                                                 PreviewKeyDown="TextBox_PreviewKeyDown"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Error message display -->
                        <TextBlock 
                                Text="{Binding ErrorMessage}" 
                                Grid.Row="2" 
                                Foreground="{StaticResource ErrorBrush}" 
                                TextAlignment="Center" 
                                FontSize="14" 
                                Margin="0,2,0,2" 
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                        <!-- Button to submit the code -->
                        <Button 
                                Grid.Row="3"
                                Content="Verify"
                                FontSize="16"
                                Width="150"
                                Height="40"
                                HorizontalAlignment="Center"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,5"
                                Command="{Binding SubmitCodeCommand}"
                                ToolTip="Submit the code to verify your identity." />

                        <!-- Button to retry code entry -->
                        <Button 
                                Grid.Row="4"
                                Content="back to mail"
                                FontSize="14"
                                Width="150"
                                Height="35"
                                HorizontalAlignment="Center"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Margin="0,10"
                                Command="{Binding RetryCommand}"
                                ToolTip="Try again to resend the verification code." />
                    </Grid>
                </DataTemplate>

                <!-- Template for the "Reset Password Step" -->
                <DataTemplate DataType="{x:Type fpvm:ResetPasswordStepViewModel}">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                        <Grid.RowDefinitions>
                            <!-- Define rows for header, password inputs, button, and error message -->
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header for resetting password -->
                        <TextBlock Grid.Row="0" 
                       Text="Reset Password" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,20,0,10"
                       Foreground="{DynamicResource MaterialDesignBody}"/>

                        <!-- Password input field -->
                        <controls:PasswordBoxWithToggle Grid.Row="2"
                            FontSize="16" 
                            Width="300" 
                            PasswordText="{Binding NewPassword, Mode=TwoWay}"
                            Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                            InnerPasswordBoxStyle="{StaticResource MaterialDesignOutlinedPasswordBox}"
                            InnerTextBoxStyle="{StaticResource MaterialDesignOutlinedTextBox}"
                            HorizontalAlignment="Center"
                            materialDesign:HintAssist.Hint="New Password"/>

                        <!-- Username Error Message -->
                        <TextBlock Text="{Binding NewPasswordErrorMessage}" 
                         Foreground="{StaticResource ErrorBrush}" 
                         Visibility="{Binding NewPasswordErrorMessage}" />

                        <!-- Confirm password input field -->
                        <controls:PasswordBoxWithToggle Grid.Row="4" 
                         PasswordText="{Binding ConfirmPassword, Mode=TwoWay}"
                         FontSize="16" 
                         Width="300" 
                         InnerPasswordBoxStyle="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         InnerTextBoxStyle="{StaticResource MaterialDesignOutlinedTextBox}"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                         Margin="0,20,0,20"
                         materialDesign:HintAssist.Hint="Confirm Password"/>

                        <!-- Button to reset password -->
                        <Button Grid.Row="5" 
                                Content="Reset Password" 
                                FontSize="16" 
                                Width="150" 
                                Height="40" 
                                HorizontalAlignment="Center"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding ResetPasswordCommand}" />

                        <!-- Error message display -->
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Grid.Row="6" Foreground="{StaticResource ErrorBrush}" 
                                   TextAlignment="Center" 
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</local:NavigablePage>
