<local:NavigablePage  x:Class="ClientApp.Views.Pages.HighScoresPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HighScoresPage">

    <Grid>
        <Border Background="#333333"
                Margin="40"
                Padding="30"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="15">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">

                <!-- Title -->
                <TextBlock Text="🏆 Leaderboards"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           Foreground="{DynamicResource MaterialDesignBody}"/>

                <!-- Top Players List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ResponseList}" Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Rank}" 
                               FontSize="23" 
                               VerticalAlignment="Bottom"
                               Foreground="{DynamicResource MaterialDesignBody}"/>
                                    <TextBlock Text="# - " 
                               FontSize="23" 
                               VerticalAlignment="Bottom"
                               Foreground="{DynamicResource MaterialDesignBody}"/>
                                    <TextBlock Text="{Binding PlayerUsername}"
                               FontSize="23" 
                               VerticalAlignment="Bottom"
                               Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>


                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                    <Button 
                        Content="Refresh"
                        Command="{Binding RefreshTopCommand}"
                        Margin="5"
                        Padding="10,5"
                        FontWeight="Bold"/>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />

            </StackPanel>
        </Border>
    </Grid>
</local:NavigablePage>
