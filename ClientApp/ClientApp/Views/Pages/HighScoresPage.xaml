<local:NavigablePage x:Class="ClientApp.Views.Pages.HighScoresPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
      Title="HighScoresPage">

    <Grid>
        <materialDesign:Card Margin="40"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxHeight="800">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Width="450">

                <!-- Title -->
                <TextBlock Text="🏆 Leaderboard"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <!-- ScrollViewer with MaxHeight -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="400">
                    <ItemsControl ItemsSource="{Binding ResponseList}" Margin="0,0,0,15">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:HighScoreUserControl/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                    <Button 
                        Content="Refresh"
                        Command="{Binding RefreshTopCommand}"
                        Margin="5"
                        Padding="10,5"
                        FontWeight="Bold"/>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</local:NavigablePage>
