<local:NavigablePage x:Class="ClientApp.Views.Pages.JoinRoomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="JoinRoomPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2.5*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <ComboBox 
            Grid.Column="1" 
            ItemsSource="{Binding Rooms}" 
            DisplayMemberPath="Name" 
            SelectedValuePath="Id" 
            Foreground="{DynamicResource MaterialDesignBody}"
            SelectedValue="{Binding SelectedRoomId}" />

        <StackPanel Grid.Row="1" Grid.Column="1" >
            <Button Content="Refresh" Margin="8" Command="{Binding RefreshCommand}"/>
            <Button Content="Join" Margin="8" Command="{Binding JoinCommand}"/>
            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" Grid.Row="2" Grid.Column="1" Foreground="Red" />
        </StackPanel>


    </Grid>
</local:NavigablePage>
