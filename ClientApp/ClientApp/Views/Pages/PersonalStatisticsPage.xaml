<local:NavigablePage x:Class="ClientApp.Views.Pages.PersonalStatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PersonalStatisticsPage">

    <Grid>
        <Border Background="#333333"
        Margin="40"
        Padding="30"
        BorderBrush="#CCCCCC"
        BorderThickness="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        CornerRadius="15">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">

                <!-- Title -->
                <TextBlock Text="Personal Statistics"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

                <!-- Personal statistics -->
                <ItemsControl ItemsSource="{Binding PersonalInfo}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding username}" FontWeight="Bold" />
                                <TextBlock Text="{Binding gamesPlayed}" FontWeight="Bold" />
                                <TextBlock Text="{Binding totalAnswers}" FontWeight="Bold" />
                                <TextBlock Text="{Binding totalCorrectAnswers}" FontWeight="Bold" />
                                <TextBlock Text="{Binding avgAnswerTime}" FontWeight="Bold" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                

                <!-- ErrorBlock -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />

            </StackPanel>
        </Border>
    </Grid>
</local:NavigablePage>
