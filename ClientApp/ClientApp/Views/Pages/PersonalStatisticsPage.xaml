<local:NavigablePage x:Class="ClientApp.Views.Pages.PersonalStatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PersonalStatisticsPage">

    <Grid>
        <Border Background="#333333"
        Margin="40"
        Padding="30"
        BorderBrush="#CCCCCC"
        BorderThickness="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        CornerRadius="15">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">

                <!-- Title -->
                <TextBlock Text="Personal Statistics"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

                <!-- Personal statistics -->
                <ItemsControl ItemsSource="{Binding PersonalInfoList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Username:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding UserName}" Margin="0,0,0,10"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>

                                <TextBlock Text="Games Played:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding GamesPlayed}" Margin="0,0,0,10"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>

                                <TextBlock Text="Total Answers:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalAnswers}" Margin="0,0,0,10"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>

                                <TextBlock Text="Correct Answers:" FontWeight="Bold"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>
                                <TextBlock Text="{Binding TotalCorrectAnswers}" Margin="0,0,0,10"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>

                                <TextBlock Text="Avg. Answer Time:" FontWeight="Bold"/>
                                <TextBlock Text="{Binding AvgAnswerTime}" Margin="0,0,0,10"
                                           Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ErrorBlock -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />

            </StackPanel>
        </Border>
    </Grid>
</local:NavigablePage>
