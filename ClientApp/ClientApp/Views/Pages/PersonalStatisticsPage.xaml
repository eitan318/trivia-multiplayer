<local:NavigablePage x:Class="ClientApp.Views.Pages.PersonalStatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PersonalStatisticsPage">

    <Grid>
        <Border Background="#333333"
        Margin="40"
        Padding="30"
        BorderBrush="#CCCCCC"
        BorderThickness="1"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        CornerRadius="15">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">

                <!-- Title -->
                <TextBlock Text="Personal Statistics"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

                <!-- Top Players -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="{Binding Top1Name}" FontSize="18" Margin="0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Top2Name}"  FontSize="18" Margin="0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Top3Name}" FontSize="18" Margin="0,4" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button 
                    Content="Refresh"
                    Command="{Binding RefreshTop3}"
                    Margin="5"
                    Padding="10,5"
                    FontWeight="Bold"/>

                </StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />

            </StackPanel>
        </Border>
    </Grid>
</local:NavigablePage>
