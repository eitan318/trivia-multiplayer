<Page x:Class="ClientApp.Views.Pages.RoomPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Pages"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RoomPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <!-- List of players displayed in a grid -->
        <ItemsControl ItemsSource="{Binding Players}">
            <!-- Define the layout for player items -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="6" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- Define the template for each player item -->
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:PlayerUserControl />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="refresh" Command="{Binding RefreshCommand}" Grid.Row="1"/>

    </Grid>
</Page>
