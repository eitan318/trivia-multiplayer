<Page x:Class="ClientApp.Views.SignupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views"
      xmlns:vm="clr-namespace:ClientApp.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignupPage">

    <Grid >
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Let's Get Started!" 
                     FontSize="20" 
                     FontWeight="Bold" 
                     TextAlignment="Center" 
                     Margin="0,0,0,20"
                     Foreground="{DynamicResource MaterialDesignBody}" />
            
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                     x:Name="UsernameTB" materialDesign:HintAssist.Hint="Username" Margin="0,10"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>

            <!-- PasswordBox -->
            <controls:PasswordBoxWithToggle
                    Margin="0,10"
                    PasswordText="{Binding Password, Mode=TwoWay}"
                    Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                    materialDesign:HintAssist.Hint="Password"/>

            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="Email" Margin="0,10" 
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            
            <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="PhoneNumber" Margin="0,10"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            
            <TextBox Text="{Binding HouseAddress, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="HouseAddress" Margin="0,10"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            
            <TextBox Text="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="BirthDate" Margin="0,10" 
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
  
            <Button Content="Signup" Margin="0,20" Padding="10,5" 
                    Command="{Binding SignupCommand}" />
            
            <Button Content="Login" Margin="0,20" Padding="10,5" 
                    Command="{Binding NavigateToLoginCommand}" 
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
            
            <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   TextAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Page>
