<Page x:Class="ClientApp.Views.SignupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views"
      xmlns:vm="clr-namespace:ClientApp.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignupPage">

    <!-- Main layout for the Signup page -->
    <Grid>
        <!-- Centered stack panel for input fields and buttons -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Page header -->
            <TextBlock Text="Let's Get Started!" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       TextAlignment="Center" 
                       Margin="0,0,0,20"
                       Foreground="{DynamicResource MaterialDesignBody}" />

            <!-- Username input -->
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                     x:Name="UsernameTB" 
                     materialDesign:HintAssist.Hint="Username"
                     Margin="0,10"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <TextBlock Text="{Binding UsernameErrorMessage}" 
                       Foreground="Red" 
                       FontSize="12"
                       Visibility="{Binding UsernameErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Password input -->
            <controls:PasswordBoxWithToggle
                    Margin="0,10"
                    PasswordText="{Binding Password, Mode=TwoWay}"
                    InnerPasswordBoxStyle="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                    InnerTextBoxStyle="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                    materialDesign:HintAssist.Hint="Password"/>
            <TextBlock Text="{Binding PasswordErrorMessage}" 
                       Foreground="Red" 
                       FontSize="12"
                       Visibility="{Binding PasswordErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Email input -->
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="Email" Margin="0,10" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <TextBlock Text="{Binding EmailErrorMessage}" 
                       Foreground="Red" 
                       FontSize="12"
                       Visibility="{Binding EmailErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Phone number input -->
            <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="PhoneNumber" Margin="0,10"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <TextBlock Text="{Binding PhoneNumberErrorMessage}" 
                       Foreground="Red" 
                       FontSize="12"
                       Visibility="{Binding PhoneNumberErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- House address input -->
            <TextBox Text="{Binding HouseAddress, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="HouseAddress" Margin="0,10"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <TextBlock Text="{Binding HouseAddressErrorMessage}" 
                       Foreground="Red" 
                       FontSize="12"
                       Visibility="{Binding HouseAddressErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

            <!-- Birthdate input -->
            <!--<TextBox Text="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged}" 
                     materialDesign:HintAssist.Hint="BirthDate" Margin="0,10"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>-->

            <DatePicker Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
            SelectedDate="{Binding BirthDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="{Binding BirthDateErrorMessage}" 
               Foreground="Red" 
               FontSize="12"
               Visibility="{Binding BirthDateErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
            
            
            
            <!-- Signup button bound to the Signup command -->
            <Button Content="Signup" Margin="0,20" Padding="10,5" 
                    Command="{Binding SignupCommand}" />

            <!-- Navigate to Login button -->
            <Button Content="Login" Margin="0,20" Padding="10,5" 
                    Command="{Binding NavigateToLoginCommand}" 
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>

            <!-- Error message display -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       TextAlignment="Center"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</Page>
