<local:NavigablePage x:Class="ClientApp.Views.Pages.StatisticsPage"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:local="clr-namespace:ClientApp.Views.Pages"
                     mc:Ignorable="d"
                     d:DesignHeight="450" d:DesignWidth="800"
                     Title="StatisticsPage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Personal statistics" Command="{Binding NavigateToPersonalStatisticsCommand}" Margin="0,10"/>
            <Button Content="High scores" Command="{Binding NavigateToHighScoresCommand}" Margin="0,10"/>
        </StackPanel>
    </Grid>
</local:NavigablePage>
