<UserControl x:Class="ClientApp.Views.Screens.CreateRoomView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ClientApp.Views.Screens"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
             
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="800"
             Style="{StaticResource UserControlStyle}"
 >
        <!-- Main Content -->
        <Grid Margin="20">
            <!-- Main layout with rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Section -->
            <Border Style="{StaticResource TitleBorderStyle}">
                <TextBlock Text="Create Room" Style="{StaticResource TitleStyle}" />
            </Border>

            <!-- Input Fields Section -->
            <Border Grid.Row="1"
                Margin="5"
                CornerRadius="16"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                BorderThickness="2">
                <ScrollViewer>
                    <UniformGrid>

                        <!-- Room Name -->
                        <TextBox 
                            materialDesign:HintAssist.Hint="Room Name" 
                            x:Name="RoomName_TB"
                            Text="{Binding CurrentRoomData.RoomName, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                            Margin="10" 
                            FontSize="14"
                            Grid.Row="0" Grid.Column="0" 
                            VerticalAlignment="Center"/>

                        <!-- Players -->
                        <materialDesign:NumericUpDown 
                            materialDesign:HintAssist.Hint="Max Players"
                            Value="{Binding CurrentRoomData.MaxPlayers, UpdateSourceTrigger=PropertyChanged}" 
                            Maximum="50" 
                            Minimum="1" 
                            Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}" 
                            Margin="10"
                            FontSize="14"
                            Grid.Row="0" Grid.Column="1"
                            VerticalAlignment="Center"/>

                        <!-- Questions -->
                        <materialDesign:NumericUpDown 
                            materialDesign:HintAssist.Hint="Questions" 
                            Value="{Binding CurrentRoomData.NumOfQuestionsInGame, UpdateSourceTrigger=PropertyChanged}" 
                            Maximum="50" 
                            Minimum="1" 
                            Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}" 
                            Margin="10" 
                            FontSize="14"
                            Grid.Row="1" Grid.Column="0"
                            VerticalAlignment="Center"/>

                        <!-- Timeout -->
                        <materialDesign:DecimalUpDown 
                            materialDesign:HintAssist.Hint="Timeout (sec)" 
                            Value="{Binding CurrentRoomData.TimePerQuestion, UpdateSourceTrigger=PropertyChanged}" 
                            ValueStep="0.5" 
                            Minimum="1" 
                            Style="{StaticResource MaterialDesignFloatingHintDecimalUpDown}" 
                            Margin="10" 
                            FontSize="14"
                            Grid.Row="1" Grid.Column="1"
                            VerticalAlignment="Center"/>

                        <!-- Score Showing Time -->
                        <materialDesign:DecimalUpDown 
                            materialDesign:HintAssist.Hint="Score Showing Time (sec)" 
                            Value="{Binding CurrentRoomData.ScoreShowingTime, UpdateSourceTrigger=PropertyChanged}" 
                            ValueStep="0.5" 
                            Minimum="1" 
                            Style="{StaticResource MaterialDesignFloatingHintDecimalUpDown}" 
                            Margin="10" 
                            FontSize="14"
                            Grid.Row="2" Grid.Column="0" 
                            VerticalAlignment="Center"/>
                    </UniformGrid>
                </ScrollViewer>
                
            </Border>

            <!-- Action Button Section -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,20,0,0">
                <!-- Create Room Button -->
                <Button Content="Create Room" 
                    Command="{Binding CreateRoomCmd}" 
                    CommandParameter="{Binding}"
                    Style="{StaticResource OperationButtonStyle}" 
                    Padding="12,8"
                    FontSize="14"
                    Margin="0,0,0,10"
                    Width="200" />

                <!-- Error Message -->
                <TextBlock 
                Text="{Binding ErrorMessage}" 
                Style="{StaticResource ErrorMessageStyle}" 
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
</UserControl>
