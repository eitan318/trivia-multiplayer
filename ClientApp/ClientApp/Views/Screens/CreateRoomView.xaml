<UserControl x:Class="ClientApp.Views.Screens.CreateRoomView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Screens"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" >

    <Grid Margin="20">
        <!-- Define rows for the layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Input Fields Section -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="0" >
            <!-- TextBox for entering the room name -->
            <TextBox 
                materialDesign:HintAssist.Hint="Room Name" 
                x:Name="RoomName_TB"
                Text="{Binding CurrentRoomData.RoomName, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Width="200"
                Margin="0,0,10,0"/>

            <!-- NumericUpDown for specifying the number of players -->
            <materialDesign:NumericUpDown
                materialDesign:HintAssist.Hint="Players" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                Value="{Binding CurrentRoomData.MaxPlayers, UpdateSourceTrigger=PropertyChanged}"
                Maximum="50"
                Minimum="1"
                Width="120"
                Margin="0,0,10,0"/>

            <!-- NumericUpDown for specifying the question count -->
            <materialDesign:NumericUpDown
                materialDesign:HintAssist.Hint="Questions" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                Maximum="50"
                Minimum="1"
                Value="{Binding CurrentRoomData.NumOfQuestionsInGame, UpdateSourceTrigger=PropertyChanged}"
                Width="120"
                Margin="0,0,10,0"/>

            <!-- NumericUpDown for specifying the question timeout -->
            <materialDesign:DecimalUpDown
                materialDesign:HintAssist.Hint="Timeout (s)" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource MaterialDesignFloatingHintDecimalUpDown}"
                Value="{Binding CurrentRoomData.TimePerQuestion, UpdateSourceTrigger=PropertyChanged}"
                ValueStep="0.5"
                Minimum="1"
                Width="120"
                Margin="0,0,10,0"/>

            <!-- NumericUpDown for specifying the question timeout -->
            <materialDesign:DecimalUpDown
                materialDesign:HintAssist.Hint="Score showing time (s)" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource MaterialDesignFloatingHintDecimalUpDown}"
                Value="{Binding CurrentRoomData.ScoreShowingTime, UpdateSourceTrigger=PropertyChanged}"
                ValueStep="0.5"
                Minimum="1"
                Width="120"
                Margin="0,0,10,0"/>
        </StackPanel>

        <!-- Button for creating the room -->
        <Button Content="Create Room" 
                Command="{Binding CreateRoomCmd}" 
                Style="{StaticResource OperationButtonStyle}"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Grid.Row="1" 
                Padding="10,5"/>

        <!-- Error Message -->
        <TextBlock Text="{Binding ErrorMessage}" 
                   Style="{StaticResource ErrorMessageStyle}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" 
                   />
    </Grid>
</UserControl>
