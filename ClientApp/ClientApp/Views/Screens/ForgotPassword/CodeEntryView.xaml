<UserControl x:Class="ClientApp.Views.Screens.ForgotPassword.CodeEntryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Screens"
      mc:Ignorable="d" 
      TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
        <Grid.RowDefinitions>
            <!-- Define rows for header, input fields, error message, and buttons -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header for code entry -->
        <TextBlock Grid.Row="0" 
Text="Enter Verification Code" 
FontSize="24" 
FontWeight="Bold" 
HorizontalAlignment="Center" 
Margin="0,20,0,10"/>

        <!-- Boxes for verification code input -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,30">
            <ItemsControl ItemsSource="{Binding CodeBoxes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBox Width="50" 
                              Height="60" 
                              FontSize="30" 
                              Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                              HorizontalContentAlignment="Center" 
                              VerticalContentAlignment="Center"
                              MaxLength="1"
                              Margin="5"
                              Foreground="{DynamicResource MaterialDesignBody}"
                              PreviewTextInput="TextBox_PreviewTextInput"
                              PreviewKeyDown="TextBox_PreviewKeyDown"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Error message display -->
        <TextBlock 
             Text="{Binding ErrorMessage}" 
             Grid.Row="2" 
             Foreground="{StaticResource ErrorBrush}" 
             TextAlignment="Center" 
             FontSize="14" 
             Margin="0,2,0,2" 
             Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

        <!-- Button to submit the code -->
        <Button 
             Grid.Row="3"
             Content="Verify"
             FontSize="16"
             Width="150"
             Height="40"
             HorizontalAlignment="Center"
             Style="{StaticResource MaterialDesignRaisedButton}"
             Margin="0,5"
             Command="{Binding SubmitCodeCmd}"
             ToolTip="Submit the code to verify your identity." />

        <!-- Button to retry code entry -->
        <Button 
             Grid.Row="4"
             Content="back to mail"
             FontSize="14"
             Width="150"
             Height="35"
             HorizontalAlignment="Center"
             Style="{StaticResource MaterialDesignFlatButton}"
             Margin="0,10"
             Command="{Binding RetryCmd}"
             ToolTip="Try again to resend the verification code." />
    </Grid>
</UserControl>
