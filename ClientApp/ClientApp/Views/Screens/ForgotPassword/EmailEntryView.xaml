<UserControl x:Class="ClientApp.Views.Screens.ForgotPassword.EmailEntryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClientApp.Views.Screens"
      mc:Ignorable="d" 
      TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
      d:DesignHeight="450" d:DesignWidth="800"
             >

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
        <Grid.RowDefinitions>
            <!-- Define rows for header, description, input, button, and error message -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <TextBlock Grid.Row="0" 
           Text="Forgot Password" 
           FontSize="24" 
           FontWeight="Bold" 
           HorizontalAlignment="Center" 
           Margin="0,20,0,10"/>

        <!-- Instruction for entering the email -->
        <TextBlock Grid.Row="1" 
           Text="Enter your email to receive a verification code:" 
           FontSize="16" 
           HorizontalAlignment="Center" 
           TextWrapping="Wrap" 
           Margin="0,0,0,10"/>

        <!-- TextBox for email input -->
        <TextBox Grid.Row="2" 
         FontSize="18" 
         Width="300" 
         HorizontalAlignment="Center" 
         Margin="0,10,0,10"
         Style="{StaticResource MaterialDesignOutlinedTextBox}"
         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Button to submit the email -->
        <Button Grid.Row="3" 
        Content="Submit" 
        FontSize="16" 
        Width="150" 
        Height="40" 
        HorizontalAlignment="Center"
        Style="{StaticResource MaterialDesignRaisedButton}"
        Command="{Binding SubmitEmailCmd}" />

        <!-- Error message display -->
        <TextBlock Text="{Binding ErrorMessage}" 
               Grid.Row="4" Foreground="{StaticResource ErrorBrush}" 
               TextAlignment="Center" 
               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</UserControl>
