<UserControl x:Class="ClientApp.Views.Screens.GameAnsweringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ClientApp.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Style="{StaticResource UserControlStyle}"
>
    <Grid Margin="10">
        <!-- Define Grid Rows and Columns -->
        <Grid.RowDefinitions>
            <!-- Game Info -->
            <RowDefinition Height="Auto" />
            <!-- Question -->
            <RowDefinition Height="4*" />
            <!-- Answers -->
            <RowDefinition Height="6*" />
            <!-- Submit Button -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Game Info -->
        <Grid Grid.Row="0" Margin="0,5,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <!-- For LeaveGame Button -->
            </Grid.ColumnDefinitions>

            <!-- Timer and Info -->
            <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
                <TextBlock Text="{Binding Timer.FormattedTime, StringFormat='Timer: {0}'}" 
                           FontWeight="Bold" FontSize="16" Margin="10,0" />
                <TextBlock Text="{Binding QuestionInfo.Category, StringFormat='Category: {0}'}" 
                           FontWeight="Bold" FontSize="16" Margin="10,0" />
                <TextBlock Text="{Binding QuestionInfo.Difficulty, StringFormat='Difficulty: {0}'}" 
                           FontWeight="Bold" FontSize="16" Margin="10,0" />
                <TextBlock Text="{Binding QDisplay, StringFormat='Q: {0}'}" 
                           FontWeight="Bold" FontSize="16" Margin="10,0" />
            </StackPanel>

            <!-- LeaveGame Button -->
            <Button 
                Content="Leave Game" 
                Command="{Binding LeaveGameCmd}"
                CommandParameter="{Binding}"
                Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" />
        </Grid>

        <!-- General Error Message -->
        <TextBlock Text="{Binding ErrorMessage}" 
                   Style="{StaticResource ErrorMessageStyle}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

        <!-- Question Text -->
        <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                BorderThickness="2" 
                Grid.Row="1"
                CornerRadius="10">
            <TextBlock 
                Text="{Binding QuestionInfo.Question}" 
                FontWeight="Bold" FontSize="20" 
                TextAlignment="Center" TextWrapping="Wrap" 
                Margin="0,10,0,10" />
        </Border>

        <!-- Answer Options -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding PossibleAnswers}" 
                 SelectedIndex="{Binding SelectedAnswerIndex}" 
                 BorderThickness="0"
                 Background="Transparent" 
                 HorizontalContentAlignment="Stretch"
                 VerticalContentAlignment="Stretch"
                 Margin="0,10,0,10">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:PossibleAnswerUserControl />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Submit Button -->
        <Button Grid.Row="3"
                Content="Submit" 
                Command="{Binding SubmitCmd}" 
                CommandParameter="{Binding}"
                FontSize="16" 
                HorizontalAlignment="Center"
                Margin="10" Padding="10" 
                Height="60"
                Width="280"
                Style="{StaticResource OperationButtonStyle}" />
    </Grid>
</UserControl>
