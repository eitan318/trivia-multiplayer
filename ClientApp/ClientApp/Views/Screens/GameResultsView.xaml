<UserControl x:Class="ClientApp.Views.Screens.GameResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientApp.Views.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- Navigation Button -->
        <Button 
            Content="← Back to Room" 
            Command="{Binding LeaveGameCmd}" 
            Style="{StaticResource OperationButtonStyle}" 
            Margin="10" 
            HorizontalAlignment="Left"
            Grid.Column="0" />

        <!-- Results Card -->
        <Border 
            Grid.Column="1" 
            Padding="20" 
            CornerRadius="16" 
            Background="{DynamicResource MaterialDesignCardBackground}" 
            >
            <StackPanel>
                <!-- Title Section -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock 
                        Text="📊 Game Results" 
                        FontSize="28" 
                        FontWeight="Bold" 
                        HorizontalAlignment="Center" />
                    <Separator HorizontalAlignment="Center" Width="120" Margin="0,10" />
                </StackPanel>

                <!-- Results List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10">
                    <ItemsControl ItemsSource="{Binding PlayersResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border 
                                    CornerRadius="12" 
                                    Background="{DynamicResource MaterialDesignPaper}" 
                                    Padding="15" 
                                    Margin="5" 
                                    BorderBrush="{DynamicResource MaterialDesignDivider}" 
                                    BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Username -->
                                        <TextBlock 
                                            Text="{Binding Username}" 
                                            FontSize="16" 
                                            FontWeight="Bold" 
                                            VerticalAlignment="Center" />

                                        <!-- Score -->
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock 
                                                Text="Score: " 
                                                FontSize="14" 
                                                Foreground="Gray" />
                                            <TextBlock 
                                                Text="{Binding Score}" 
                                                FontSize="14" 
                                                FontWeight="Bold" />
                                        </StackPanel>

                                        <!-- Correct Answers -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock 
                                                Text="Correct: " 
                                                FontSize="14" 
                                                Foreground="Gray" />
                                            <TextBlock 
                                                Text="{Binding CorrectAnswerCount}" 
                                                FontSize="14" 
                                                FontWeight="Bold" />
                                        </StackPanel>

                                        <!-- Wrong Answers -->
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock 
                                                Text="Wrong: " 
                                                FontSize="14" 
                                                Foreground="Gray" />
                                            <TextBlock 
                                                Text="{Binding WrongAnswerCount}" 
                                                FontSize="14" 
                                                FontWeight="Bold" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
