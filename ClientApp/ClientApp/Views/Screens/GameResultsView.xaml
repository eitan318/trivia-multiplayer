<UserControl x:Class="ClientApp.Views.Screens.GameResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientApp.Views.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Button 
            Margin="10"
            VerticalAlignment="Bottom"
            Grid.Column="2"
            Content="To Room" Command="{Binding LeaveGameCmd}"
            />
        
        
        <!--Whole Card-->
        <materialDesign:Card 
        Grid.Column="1"
        Margin="20"
        Padding="30"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        MaxHeight="800"
        MinWidth="300">
            <Grid>
                <!-- Define rows for the layout -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="*"/>
                    <!-- Scrollable Content -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons and Error Message -->
                </Grid.RowDefinitions>

                <StackPanel Orientation="Vertical">
                    <!-- Title -->
                    <TextBlock Grid.Row="0" Text="📊 Game Results"
                        FontSize="30"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15"/>

                    <!--Data Grid of The Game's Results-->
                    <DataGrid Grid.Column="0" ItemsSource="{Binding Players}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="User's Name" Binding="{Binding Username}" />
                            <DataGridTextColumn Header="Correct Answers" Binding="{Binding CorrectAnswerCount}" />
                            <DataGridTextColumn Header="Average Answer Time" Binding="{Binding AverageAnswerTime}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
        

    </Grid>
</UserControl>
