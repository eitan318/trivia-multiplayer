<UserControl x:Class="ClientApp.Views.Screens.GameResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientApp.Views.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
                   TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- Navigation Button -->
        <Button 
            Content="Back to Room" 
            Command="{Binding LeaveGameCmd}" 
            Style="{StaticResource OperationButtonStyle}" 
            Margin="10" 
            VerticalAlignment="Bottom" 
            Grid.Column="2" />

        <!-- Card for Results -->
        <materialDesign:Card 
            Grid.Column="1" 
            Padding="20" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Background="{DynamicResource MaterialDesignPaper}"
            MaxWidth="600">
            <StackPanel>
                <!-- Title -->
                <TextBlock 
                    Text="📊 Game Results" 
                    FontSize="24" 
                    FontWeight="Bold" 
                    TextAlignment="Center" 
                    Margin="0,0,0,20" />

                <!-- Results List -->
                <ListView ItemsSource="{Binding PlayersResults}" Margin="0,10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Background="{DynamicResource MaterialDesignCardBackground}" Padding="10" Margin="5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Username -->
                                    <TextBlock 
                                        Text="{Binding Username}" 
                                        FontSize="16" 
                                        FontWeight="Bold" 
                                        Margin="0,0,10,0" />

                                    <!-- Score -->
                                    <TextBlock 
                                        Text="Score: " 
                                        FontSize="14" 
                                        Foreground="Gray" />
                                    <TextBlock 
                                        Text="{Binding Score}" 
                                        FontSize="14" 
                                        FontWeight="Bold" />

                                    <!-- Spacer -->
                                    <Separator Width="20" Opacity="0" />

                                    <!-- Additional Stats -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock 
                                            Text="Correct: " 
                                            FontSize="14" 
                                            Foreground="Gray" />
                                        <TextBlock 
                                            Text="{Binding CorrectAnswerCount}" 
                                            FontSize="14" 
                                            FontWeight="Bold" />

                                        <Separator Width="10" Opacity="0" />

                                        <TextBlock 
                                            Text="Wrong: " 
                                            FontSize="14" 
                                            Foreground="Gray" />
                                        <TextBlock 
                                            Text="{Binding WrongAnswerCount}" 
                                            FontSize="14" 
                                            FontWeight="Bold" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
