<UserControl x:Class="ClientApp.Views.Screens.GameResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientApp.Views.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Style="{StaticResource UserControlStyle}">

    <DockPanel Margin="20">
        <!-- Floating Back Button -->
        <Button 
            Content="← Back to Room" 
            Command="{Binding LeaveGameCmd}" 
            Style="{StaticResource OperationButtonStyle}" 
            Margin="0,0,0,30"
            Height="40"
            DockPanel.Dock="Bottom" 
            MaxWidth="250"/>

        <!-- Results Card -->
            <StackPanel Margin="30">
                <!-- Title Section -->
                <Border Style="{StaticResource TitleBorderStyle}">
                    <TextBlock Text="📊 Game Results" Style="{StaticResource TitleStyle}" />
                </Border>

                <!-- Results List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10">
                    <ItemsControl ItemsSource="{Binding PlayersResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ListItemStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Username -->
                                        <TextBlock 
                                            Text="{Binding Username}" 
                                            FontSize="16" 
                                            FontWeight="Bold" 
                                            VerticalAlignment="Center" />

                                        <!-- Score -->
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock 
                                                Text="Score: " 
                                                FontSize="14" 
                                                Foreground="Gray" />
                                            <TextBlock 
                                                Text="{Binding Score}" 
                                                FontSize="14" 
                                                FontWeight="Bold" />
                                        </StackPanel>

                                        <!-- Correct Answers -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock 
                                                Text="Correct: " 
                                                FontSize="14" 
                                                Foreground="Gray" />
                                            <TextBlock 
                                                Text="{Binding CorrectAnswerCount}" 
                                                FontSize="14" 
                                                FontWeight="Bold" />
                                        </StackPanel>

                                        <!-- Wrong Answers -->
                                        <StackPanel Grid.Column="3" HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock 
                                                Text="Wrong: " 
                                                FontSize="14" 
                                                Foreground="Gray" />
                                            <TextBlock 
                                                Text="{Binding WrongAnswerCount}" 
                                                FontSize="14" 
                                                FontWeight="Bold" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
    </DockPanel>
</UserControl>
