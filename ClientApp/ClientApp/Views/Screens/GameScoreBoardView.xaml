<UserControl x:Class="ClientApp.Views.Screens.GameScoreBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientApp.Views.Screens"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Button 
            Margin="10"
            VerticalAlignment="Bottom"
            Grid.Column="2"
            Content="To Room" Command="{Binding LeaveGameCmd}"
            Style="{StaticResource OperationButtonStyle}"
            />
        
        <materialDesign:Card 
Grid.Column="1"
Margin="20"
Padding="30"
HorizontalAlignment="Center"
VerticalAlignment="Center"
MaxHeight="800"
MinWidth="300">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="*"/>
                    <!-- Scrollable Content -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons and Error Message -->
                </Grid.RowDefinitions>

                <StackPanel Orientation="Vertical">
                    <!-- Title -->
                    <TextBlock Grid.Row="0"
                               Text="Game Scores"
                               Style="{StaticResource TitleStyle}" 
                               />

                    <!--Data Grid of The Game's Results-->
                    <DataGrid Grid.Column="0" ItemsSource="{Binding PlayersResults}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="User's Name" Binding="{Binding Username}" />
                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" />

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </materialDesign:Card>


    </Grid>
</UserControl>
