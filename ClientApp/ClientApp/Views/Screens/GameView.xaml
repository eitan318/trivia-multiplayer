<UserControl x:Class="ClientApp.Views.Screens.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ClientApp.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
    <Grid Margin="10">
        <!-- Define Grid Rows and Columns -->
        <Grid.RowDefinitions>
            <!-- Game Info -->
            <RowDefinition Height="Auto" />
            <!-- Question -->
            <RowDefinition Height="Auto" />
            <!-- Answers -->
            <RowDefinition Height="*" />
            <!-- Submit Button -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Game Info Panel -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Center" Margin="0,5,0,10">
            <TextBlock Text="{Binding Score, StringFormat='Score: {0}'}" 
                       FontWeight="Bold" FontSize="16" Margin="10,0" />
            <TextBlock Text="{Binding Timer.FormattedTime, StringFormat='Timer: {0}'}" 
                       FontWeight="Bold" FontSize="16" Margin="10,0" />
            <TextBlock Text="{Binding QuestionInfo.Category, StringFormat='Category: {0}'}" 
                       FontWeight="Bold" FontSize="16" Margin="10,0" />
            <TextBlock Text="{Binding QuestionInfo.Difficulty, StringFormat='Difficulty: {0}'}" 
                       FontWeight="Bold" FontSize="16" Margin="10,0" />
            <TextBlock Text="{Binding QDisplay, StringFormat='Q: {0}'}" 
                       FontWeight="Bold" FontSize="16" Margin="10,0" />
            <Button Content="LeaveGame" Command="{Binding LeaveGameCmd}"/>
        </StackPanel>

        <!-- Question Text -->
        <TextBlock Grid.Row="1"
                   Text="{Binding Question}" 
                   FontWeight="Bold" FontSize="20" 
                   TextAlignment="Center" TextWrapping="Wrap" 
                   Margin="0,10,0,10" />

        <!-- Answer Options -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding PossibleAnswers}" 
                 SelectedIndex="{Binding SelectedAnswerIndex}" 
                 BorderThickness="0" Background="Transparent" 
                 Margin="0,10,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <controls:PossibleAnswerUserControl/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Submit Button -->
        <Button Grid.Row="3"
                Content="Submit" Command="{Binding SubmitCmd}" 
                FontWeight="Bold" FontSize="16" 
                HorizontalAlignment="Center"
                Margin="10" Padding="10" 
                Height="40"
                Width="80"
                Style="{StaticResource MaterialDesignFlatButton}" />
    </Grid>
</UserControl>
