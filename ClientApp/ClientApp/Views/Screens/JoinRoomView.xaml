<UserControl x:Class="ClientApp.Views.Screens.JoinRoomView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:ClientApp.Views.Screens"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
             Style="{StaticResource UserControlStyle}">
    
    <!-- Main Content -->
        <Grid Margin="20">
            <!-- Define Grid Columns -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Define Grid Rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search Box -->
            <TextBox
            x:Name="Search_TBX"
            Grid.Row="0"
            Grid.Column="1"
            Margin="0,0,0,10"
            materialDesign:HintAssist.Hint="Search by ID or Name..."
            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
            Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Selectable Scrollable Room List -->
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <ListBox
                ItemsSource="{Binding FilteredRooms}"
                SelectedItem="{Binding SelectedRoom}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <controls:RoomPreviewUserControl 
                        DataContext="{Binding}" 
                        SearchQuery="{Binding DataContext.SearchQuery, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Border>


            <!-- Action Buttons and Error Message -->
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center">
                <Button 
                Content="Join" 
                Margin="8"
                Style="{StaticResource OperationButtonStyle}"
                Command="{Binding JoinCmd}"
                CommandParameter="{Binding}"
                Width="150"
                Height="40" />
                <TextBlock 
                Text="{Binding ErrorMessage}" 
                Foreground="Red" TextWrapping="Wrap" Margin="10" />
            </StackPanel>
        </Grid>
</UserControl>
