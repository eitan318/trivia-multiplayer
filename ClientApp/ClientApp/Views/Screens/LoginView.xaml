<UserControl x:Class="ClientApp.Views.Screens.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      mc:Ignorable="d" 
             Style="{StaticResource UserControlStyle}"

      d:DesignHeight="450" d:DesignWidth="800"
      >

    <Grid Background="{DynamicResource MaterialDesignPaper}">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Centered Card for Login Form -->
        <materialDesign:Card Grid.Row="1" Width="400" Padding="20" >

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Page Title -->
                <TextBlock Text="Welcome! Please Log In" 
                           Style="{StaticResource TitleStyle}" 
                           Margin="20"
                          />

                <!-- Username TextBox -->
                <TextBox
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                    x:Name="UsernameTB"
                    materialDesign:HintAssist.Hint="Username" 
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    />

                <!-- Username Error Message -->
                <TextBlock Text="{Binding UsernameErrorMessage}" 
                   Style="{StaticResource ErrorMessageStyle}"
                   Visibility="{Binding UsernameErrorMessage}" />

                <!-- PasswordBox with Show/Hide Toggle -->
                <controls:PasswordBoxWithToggle
                    PasswordText="{Binding Password, Mode=TwoWay}"
                    InnerPasswordBoxStyle="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                    InnerTextBoxStyle="{StaticResource MaterialDesignFloatingHintTextBox}"
                    materialDesign:HintAssist.Hint="Password">
                </controls:PasswordBoxWithToggle>

                <!-- Password Error Message -->
                <TextBlock Text="{Binding PasswordErrorMessage}" 
                            Style="{StaticResource ErrorMessageStyle}"
                    Visibility="{Binding PasswordErrorMessage}" />

                <!-- General Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}" 
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <!-- Spacer for better alignment -->
                <Grid Height="20"/>

                <!-- Forgot Password Hyperlink -->
                <TextBlock>
                    <Hyperlink Command="{Binding NavToForgotPasswordCmd}" 
                               Style="{StaticResource HyperlinkStyle}">
                        Forgot My Password
                    </Hyperlink>
                </TextBlock>

                <!-- Login Button -->
                <Button Content="Login"
                    Command="{Binding LoginCmd}"
                    CommandParameter="{Binding}"
                    Margin="0,20"
                    Padding="10,5" 
                    Width="200"
                    Height="40"
                    Style="{StaticResource OperationButtonStyle}"
                    />

                <!-- Sign Up Button -->
                <Button Content="Signup"
                    Command="{Binding NavToSignupCmd}"
                    Style="{StaticResource LoginToggleStyle}" />


            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
