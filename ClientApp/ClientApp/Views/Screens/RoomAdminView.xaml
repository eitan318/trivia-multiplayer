<UserControl x:Class="ClientApp.Views.Screens.RoomAdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:ClientApp.Views.Screens"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Admin Display -->
        <materialDesign:Card Grid.ColumnSpan="2" UniformCornerRadius="22" BorderBrush="{StaticResource MaterialDesignLightSeparatorBackground}" BorderThickness="3">
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Admin (You):" FontSize="16" FontWeight="Bold" Margin="10"/>
                <controls:PlayerUserControl DataContext="{Binding Admin}"  Margin="0,0,100,0"/>
                <controls:RoomDataUserControl DataContext="{Binding RoomDataStore.CurrentRoomData}" Margin="0,0,0,10" />
            </StackPanel>
        </materialDesign:Card>
        

        <!-- List of players -->
        <GroupBox Header="Players" Grid.Row="1" Grid.Column="0" Margin="0,10,10,10">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Players}">
                    <!-- Define the layout for player items -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <!-- Define the template for each player item -->
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:PlayerUserControl Margin="10"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>


        <materialDesign:Card Margin="10" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" UniformCornerRadius="22" BorderBrush="{StaticResource MaterialDesignLightSeparatorBackground}" BorderThickness="3">
            <!-- Action Buttons -->
            <StackPanel  Margin="10,10,0,10" VerticalAlignment="Top">
                <Button Content="Start Game" 
                    Command="{Binding StartGameCmd}" Margin="0,0,0,10" 
                    materialDesign:ButtonAssist.CornerRadius="16"
                        Style="{StaticResource OperationButtonStyle}"
                    BorderThickness="3"
                    Width="200"
                    Height="40"
                    FontWeight="Bold"/>
                <Button 
                    Content="Close Room" 
                    Command="{Binding CloseRoomCmd}"
                    Style="{StaticResource OperationButtonStyle}"
                    materialDesign:ButtonAssist.CornerRadius="16"
                    BorderThickness="3"
                    Width="200"
                    Height="40"
                    FontWeight="Bold"/>

                <TextBlock Text="{Binding ErrorMessage}" 
                           Style="{StaticResource ErrorMessageStyle}"
                            Visibility="{Binding ErrorMessage}" />
            </StackPanel>
        </materialDesign:Card>
        
    </Grid>
</UserControl>
