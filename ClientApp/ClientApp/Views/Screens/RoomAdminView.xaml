<UserControl x:Class="ClientApp.Views.Screens.RoomAdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:ClientApp.Views.Screens"
      xmlns:controls="clr-namespace:ClientApp.Views.Controls"
      TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Admin and Room Info -->
        <Border
                CornerRadius="22"
                BorderBrush="{StaticResource PrimaryColor}"
                BorderThickness="2" 
            Grid.ColumnSpan="2" 
            Margin="0,0,0,10" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Admin (You):" FontSize="16" FontWeight="Bold" Margin="10,0,10,0" />
                    <controls:PlayerUserControl DataContext="{Binding Admin}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,10,0">
                        <TextBlock Text="name"  HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="0" Text="{Binding RoomDataStore.CurrentRoomData.RoomName}"
                               FontWeight="Bold" FontSize="28" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="10,0,0,0">
                        <TextBlock Text="Id"  HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding RoomDataStore.CurrentRoomData.Id, StringFormat='#{0}'}"
                               FontWeight="Bold" FontSize="30" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical">
                    <TextBlock Text="{Binding PlayersInfo}" />
                    <TextBlock Text="{Binding RoomDataStore.CurrentRoomData.NumOfQuestionsInGame, StringFormat='Questions: {0}'}" />
                    <TextBlock Text="{Binding RoomDataStore.CurrentRoomData.TimePerQuestion, StringFormat='Time per Question: {0} sec'}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- List of Players -->
        <Border Grid.Row="1"
        Padding="3"
        CornerRadius="18"
        BorderBrush="{StaticResource PrimaryColor}"
        Background="{StaticResource PrimaryColor}"
        BorderThickness="2" 
        Grid.Column="0" 
        Margin="0,10,10,10">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header row -->
                    <RowDefinition Height="Auto" />
                    <!-- Player list row (fills available space) -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Text="Players"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="5"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

                <!-- Inner Border for Player List -->
                <Border Grid.Row="1"
                Padding="10"
                CornerRadius="18"
                BorderBrush="{StaticResource PrimaryColor}"
                        Background="{DynamicResource MaterialDesign.Brush.Background}"
                BorderThickness="1">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Players}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controls:PlayerUserControl Margin="10" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>



        <!-- Action Buttons -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Margin="10" 
                Padding="20"
                CornerRadius="22"
                BorderBrush="{StaticResource PrimaryColor}"
                BorderThickness="2">
            <StackPanel VerticalAlignment="Top" >
                <Button Content="Start Game" 
                        Command="{Binding StartGameCmd}"
                        Style="{StaticResource OperationButtonStyle}"
                        Height="40"
                        Margin="10"/>
                <Button Content="Close Room" 
                        Command="{Binding CloseRoomCmd}"
                        Style="{StaticResource OperationButtonStyle}"
                        Height="40"
                        Margin="10"/>
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
