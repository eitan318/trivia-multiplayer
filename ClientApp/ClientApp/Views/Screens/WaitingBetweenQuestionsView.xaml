<UserControl x:Class="ClientApp.Views.Screens.WaitingBetweenQuestionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientApp.Views.Screens"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
            <!-- Loading animation -->
            <ProgressBar
                IsIndeterminate="True"
                Width="40"
                Style="{StaticResource MaterialDesignCircularProgressBar}"
                Value="0"/>

                <Button 
            Margin="10"
            VerticalAlignment="Bottom"
            Grid.Column="2"
            Content="To Room" Command="{Binding LeaveGameCmd}"
            />

            <!-- Loading text -->
            <TextBlock Text="Waiting for everyone to answer..." 
                       FontSize="16" 
                       Foreground="Gray" 
                       TextAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
